<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.novalearn.controllers.BlogFront">
    <children>
        <BorderPane styleClass="gradient-background" stylesheets="@../org/novalearn/alertStyles.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <bottom>
                <VBox alignment="TOP_CENTER" spacing="10" BorderPane.alignment="BOTTOM_CENTER">
                    <children>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="Infinity" prefHeight="500.0" vbarPolicy="AS_NEEDED">
                            <content>
                                <StackPane alignment="TOP_CENTER">
                                    <VBox fx:id="postBackground" alignment="TOP_CENTER" maxWidth="700" prefWidth="700" spacing="10.0" styleClass="post-background" stylesheets="@../org/novalearn/alertStyles.css">
                                        <Pagination fx:id="pagination" maxPageIndicatorCount="5" />
                                    </VBox>
                                </StackPane>
                            </content>
                        </ScrollPane>

                    </children>
                </VBox>
            </bottom>

            <top>
                <Pane prefHeight="100.0" BorderPane.alignment="CENTER">
                    <styleClass>
                        <String fx:value="line-color" />
                    </styleClass>
                    <children>
                        <ImageView fitHeight="110.0" fitWidth="306.0" layoutX="25.0" layoutY="7.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../org/novalearn/logooo.png" />
                            </image>
                        </ImageView>
                    </children>
                </Pane>
            </top>
        </BorderPane>
    </children>
</AnchorPane>
