<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.novalearn.controllers.AccueilController"
            style="-fx-background-color: #8A2BE2;">

    <!-- Barre latérale cachée -->
    <left>
        <VBox fx:id="sideMenu"
              style="-fx-background-color: #4B0082; -fx-padding: 10; -fx-spacing: 10;"
              prefWidth="200"
              visible="false"
              translateX="-200">

            <Button text="Accueil" onAction="#showAccueilBody"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button text="Réclamation" onAction="#showReclamation"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button fx:id="btnQuiz" text="Quizzes" onAction="#showQuizzes"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button fx:id="btnCoursAdmin" text="Cours Admin" onAction="#showCoursAdmin"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button fx:id="btnExerciceAdmin" text="Exercice Admin" onAction="#showCoursExerciceAdmin"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button fx:id="btnReclamationAdmin" text="Réclamations Admin" onAction="#showAReclamation"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button fx:id="btnAIcours" text="AI Cours" onAction="#SohwAIcours"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button fx:id="btnBlogAdmin" text="Blogs Admin" onAction="#SohwBlogAdmin"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button text="Blogs Front" onAction="#SohwBlogFront"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button text="Cours / Exercice" onAction="#showCoursExercice"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>

            <Button text="Messagerie" onAction="#showMessagerie"
                    style="-fx-background-color: #6a11cb; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 10; -fx-padding: 10 20;
                   -fx-pref-width: 180; -fx-pref-height: 40;"/>
        </VBox>


    </left>

    <!-- Barre supérieure -->
    <top>
        <HBox style="-fx-background-color: #4B0082; -fx-padding: 10;" spacing="10" alignment="CENTER_LEFT">
            <!-- Logo -->
            <ImageView fx:id="logoImageView"
                       fitHeight="40"
                       preserveRatio="true"
                       smooth="true">
                <image>
                    <Image url="/org/novalearn/logooo.png"/>
                </image>
            </ImageView>

            <!-- Bouton menu ☰ -->
            <Button text="☰"
                    onAction="#toggleMenu"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 20px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Déconnexion"
                    onAction="#onLogoutClicked"
                    style="-fx-background-color: #FFD700; -fx-text-fill: black; -fx-font-weight: bold; -fx-background-radius: 20;"/>
        </HBox>
    </top>

    <!-- Contenu central avec design décoré -->
    <center>
        <StackPane fx:id="contentPane"
                   style="-fx-background-color: #8A2BE2; -fx-padding: 20;">

            <VBox alignment="CENTER"
                  spacing="20"
                  style="-fx-background-color: #8A2BE2;">
                <padding>
                    <Insets top="40" bottom="40" left="60" right="60"/>
                </padding>

                <Text text="Découvrez la magie de l'apprentissage avec NovaLearn"
                      style="-fx-fill: #FFFFFF; -fx-font-size: 36px; -fx-font-weight: bold; -fx-text-alignment: center;"
                      wrappingWidth="700"/>

                <Text text="Bienvenue sur Studyhub où chaque jour apporte de nouvelles opportunités de découverte et de croissance. Notre communauté vibrante est dévouée à votre réussite."
                      wrappingWidth="600"
                      style="-fx-fill: white; -fx-font-size: 18px; -fx-text-alignment: center;" />

                <HBox spacing="20" alignment="CENTER">
                    <Button text="Explorer maintenant"
                            style="-fx-background-color: #FFD700; -fx-text-fill: #000000; -fx-font-size: 16px; -fx-background-radius: 30; -fx-padding: 10 20;"/>

                    <Button text="► Regarder la vidéo"
                            style="-fx-background-color: #FFFFFF; -fx-text-fill: #000000; -fx-font-size: 16px; -fx-background-radius: 30; -fx-padding: 10 20;"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
