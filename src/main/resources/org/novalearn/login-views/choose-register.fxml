<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20" style="-fx-background-color: #8A2BE2;" xmlns:fx="http://javafx.com/fxml" fx:controller="org.novalearn.controllers.user.ChooseRegisterController">
    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Text text="Discover the Magic of Learning at" fill="WHITE" style="-fx-font-size: 36px;"/>
    <Text text="Novalearn" fill="#FFD700" style="-fx-font-size: 48px; -fx-font-weight: bold;"/>

    <Text text="Welcome to Studyhub where each day brings new opportunities for discovery and growth. Our vibrant community is dedicated."
          fill="WHITE" wrappingWidth="600" textAlignment="CENTER" style="-fx-font-size: 18px;"/>

    <HBox alignment="CENTER" spacing="20">
        <Button text="S'inscrire en tant qu'élève" onAction="#onStudentRegisterClicked"
                style="-fx-background-color: #FFD700; -fx-text-fill: black; -fx-font-size: 16px; -fx-padding: 10 20; -fx-background-radius: 20;"/>

        <Button text="S'inscrire en tant que parent" onAction="#onParentRegisterClicked"
                style="-fx-background-color: #FFD700; -fx-text-fill: black; -fx-font-size: 16px; -fx-padding: 10 20; -fx-background-radius: 20;"/>
    </HBox>

    <Button text="Retour" onAction="#onBackClicked"
            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 20;"/>
</VBox>