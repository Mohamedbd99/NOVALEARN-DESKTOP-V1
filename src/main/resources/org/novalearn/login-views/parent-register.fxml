<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20" style="-fx-background-color: #8A2BE2;" xmlns:fx="http://javafx.com/fxml" fx:controller="org.novalearn.controllers.user.ParentRegisterController">
    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Text text="Inscription Étudiant" fill="WHITE" style="-fx-font-size: 36px; -fx-font-weight: bold;"/>

    <GridPane vgap="15" hgap="10" maxWidth="400">
        <TextField fx:id="nomField" promptText="Nom"
                   style="-fx-background-radius: 20; -fx-background-color: white;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>

        <TextField fx:id="prenomField" promptText="Prénom"
                   style="-fx-background-radius: 20; -fx-background-color: white;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

        <TextField fx:id="emailField" promptText="Email"
                   style="-fx-background-radius: 20; -fx-background-color: white;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>

        <TextField fx:id="numTelField" promptText="Numéro de téléphone"
                   style="-fx-background-radius: 20; -fx-background-color: white;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>

        <TextField fx:id="ageField" promptText="Âge"
                   style="-fx-background-radius: 20; -fx-background-color: white;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>

        <ComboBox fx:id="genreComboBox" promptText="Genre"
                  style="-fx-background-radius: 20; -fx-background-color: white;" GridPane.columnIndex="0" GridPane.rowIndex="5"/>

        <TextField fx:id="specialiteField" promptText="Specialite"
                   style="-fx-background-radius: 20; -fx-background-color: white;" GridPane.columnIndex="0" GridPane.rowIndex="6"/>

        <PasswordField fx:id="passwordField" promptText="Mot de passe"
                       style="-fx-background-radius: 20; -fx-background-color: white;" GridPane.columnIndex="0" GridPane.rowIndex="7"/>

        <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe"
                       style="-fx-background-radius: 20; -fx-background-color: white;" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
    </GridPane>

    <HBox spacing="20" alignment="CENTER">
        <Button text="S'inscrire" onAction="#onRegisterClicked"
                style="-fx-background-color: #FFD700; -fx-text-fill: black; -fx-font-size: 16px; -fx-padding: 10 20; -fx-background-radius: 20;"/>

        <Button text="Retour" onAction="#onBackClicked"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 20;"/>
    </HBox>
</VBox>