<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="CENTER" style="-fx-background-color: #8A2BE2;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.novalearn.controllers.user.VerifyEmailController">

    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Label text="Vérification de votre email"
           style="-fx-text-fill: white; -fx-font-size: 36px;"/>

    <Label text="Entrez le code de vérification envoyé à votre adresse email"
           style="-fx-text-fill: white; -fx-font-size: 18px;"
           wrapText="true" maxWidth="600" textAlignment="CENTER"/>

    <TextField fx:id="verificationCodeField" promptText="Code de vérification"
               style="-fx-background-radius: 20; -fx-background-color: white;"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Vérifier" onAction="#handleVerify"
                style="-fx-background-color: #FFD700; -fx-text-fill: black; -fx-font-size: 16px; -fx-padding: 10 20; -fx-background-radius: 20;"/>

        <Button text="Retour" onAction="#handleBack"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 20;"/>
    </HBox>
</VBox>
