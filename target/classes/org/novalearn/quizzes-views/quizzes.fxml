<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.novalearn.controllers.QuizzesController">
    <Label text="Module Quizzes" style="-fx-font-size: 16px;"/>
    <Label text="Entrez votre texte:"/>
    <TextArea fx:id="promptArea" promptText="Entrez votre texte ici..."/>
    <Button text="Soumettre" onAction="#onSubmit"/>
    <TextArea fx:id="responseArea" editable="false" promptText="La réponse de l'API sera affichée ici..."/>
    <!-- add your UI here -->
</VBox>
